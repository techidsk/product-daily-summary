# ── 前端直读（浏览器，可公开）──────────────────────────────────
# Vite 会把 VITE_ 变量注入前端。publishable/anon key 可公开。
# Supabase 控制台 → Project Settings → API Keys
VITE_SUPABASE_URL=https://YOUR_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxx

# ── 入库（服务端：本地 / GitHub Actions）切勿暴露到前端 ──────────
# Supabase → Connect → Session pooler（IPv4/5432；别用 IPv6-only 的 Direct）
DATABASE_URL=postgresql://postgres.YOUR_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# 复制为 .env 填真实值；.env 已 gitignore。
# 部署：VITE_* 配到 Cloudflare Pages 环境变量；DATABASE_URL 配到 GitHub Actions secret。
